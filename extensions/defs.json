{
  "language_id": "darcy",
  "scope": "source.darcy",
  "file_extensions": [
    "dsl"
  ],
  "keywords": [
    "def",
    "defn",
    "defin",
    "defmacro",
    "defrecord",
    "defenum",
    "extern",
    "quote",
    "syntax-quote",
    "unquote",
    "unquote-splicing",
    "with-meta",
    "case",
    "cond",
    "and",
    "or",
    "when",
    "if",
    "do",
    "loop",
    "while",
    "for",
    "break",
    "continue",
    "let",
    "fn",
    "call",
    "require",
    "list",
    "vec",
    "set",
    "hashset",
    "range",
    "range-incl",
    "true",
    "false",
    "nil"
  ],
  "types": [
    "i32",
    "i64",
    "u32",
    "u64",
    "f32",
    "f64",
    "bool",
    "usize",
    "isize",
    "string",
    "hashset",
    "hash-map",
    "btree-map",
    "()"
  ],
  "builtins": [
    "darcy.io/dbg",
    "darcy.fmt/format",
    "darcy.fmt/pretty",
    "darcy.fmt/print",
    "darcy.fmt/println",
    "darcy.math/abs",
    "darcy.math/min",
    "darcy.math/max",
    "darcy.math/clamp",
    "darcy.vec/len",
    "darcy.vec/is-empty",
    "darcy.vec/get",
    "darcy.vec/set",
    "darcy.string/len",
    "darcy.string/is-empty",
    "darcy.string/trim",
    "darcy.string/split",
    "darcy.string/join",
    "darcy.option/some",
    "darcy.option/none",
    "darcy.option/is-some",
    "darcy.option/is-none",
    "darcy.option/unwrap",
    "darcy.option/unwrap-or",
    "darcy.result/ok",
    "darcy.result/err",
    "darcy.result/is-ok",
    "darcy.result/is-err",
    "darcy.result/unwrap",
    "darcy.result/unwrap-or",
    "darcy.hash-map/new",
    "darcy.hash-map/len",
    "darcy.hash-map/is-empty",
    "darcy.hash-map/get",
    "darcy.hash-map/contains",
    "darcy.hash-map/insert",
    "darcy.hash-map/remove",
    "darcy.btree-map/new",
    "darcy.btree-map/len",
    "darcy.btree-map/is-empty",
    "darcy.btree-map/get",
    "darcy.btree-map/contains",
    "darcy.btree-map/insert",
    "darcy.btree-map/remove"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/"
  ],
  "comment_line": ";",
  "comment_block": [
    "#|",
    "|#"
  ]
}