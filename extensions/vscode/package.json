{
  "name": "darcy-language",
  "displayName": "Darcy Language",
  "description": "Language support and LSP client for Darcy (.dsl)",
  "version": "0.1.0",
  "publisher": "darcy-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:darcy"
  ],
  "main": "./extension.js",
  "scripts": {
    "grammar:update": "python3 ../gen_grammars.py",
    "grammar:check": "python3 ../gen_grammars.py && git diff --exit-code -- syntaxes/darcy.tmLanguage.json ../zed/darcy.tmLanguage.json"
  },
  "contributes": {
    "configuration": {
      "title": "Darcy",
      "properties": {
        "darcy.languageServer.path": {
          "type": "string",
          "default": "darcy-lsp",
          "description": "Path to darcy-lsp binary"
        },
        "darcy.languageServer.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to darcy-lsp"
        }
      }
    },
    "languages": [
      {
        "id": "darcy",
        "aliases": [
          "Darcy",
          "darcy"
        ],
        "extensions": [
          ".dsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "darcy",
        "scopeName": "source.darcy",
        "path": "./syntaxes/darcy.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
