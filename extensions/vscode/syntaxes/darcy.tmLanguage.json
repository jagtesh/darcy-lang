{
  "name": "Darcy",
  "scopeName": "source.darcy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.darcy",
          "match": ";.*$"
        },
        {
          "name": "comment.block.darcy",
          "begin": "\\#\\|",
          "end": "\\|\\#"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.darcy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.darcy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.darcy",
          "match": "-?\\\\b\\\\d+\\\\.\\\\d+(?:[eE][+-]?\\\\d+)?\\\\b"
        },
        {
          "name": "constant.numeric.integer.darcy",
          "match": "-?\\\\b\\\\d+\\\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.darcy",
          "match": "(?:\\\\bunquote\\-splicing\\\\b|\\\\bsyntax\\-quote\\\\b|\\\\brange\\-incl\\\\b|\\\\bdefrecord\\\\b|\\\\bwith\\-meta\\\\b|\\\\bcontinue\\\\b|\\\\bdefmacro\\\\b|\\\\bdefenum\\\\b|\\\\bhashset\\\\b|\\\\brequire\\\\b|\\\\bunquote\\\\b|\\\\bextern\\\\b|\\\\bbreak\\\\b|\\\\bdefin\\\\b|\\\\bfalse\\\\b|\\\\bquote\\\\b|\\\\brange\\\\b|\\\\bwhile\\\\b|\\\\bcall\\\\b|\\\\bcase\\\\b|\\\\bcond\\\\b|\\\\bdefn\\\\b|let!|\\\\blist\\\\b|\\\\bloop\\\\b|\\\\btrue\\\\b|\\\\bwhen\\\\b|\\\\band\\\\b|\\\\bdef\\\\b|\\\\bfor\\\\b|\\\\blet\\\\b|\\\\bnil\\\\b|\\\\bset\\\\b|\\\\bvec\\\\b|\\\\bdo\\\\b|\\\\bfn\\\\b|\\\\bif\\\\b|\\\\bor\\\\b)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.darcy",
          "match": "(?:\\\\bbtree\\-map\\\\b|\\\\bhash\\-map\\\\b|\\\\bhashset\\\\b|\\\\bstring\\\\b|\\\\bisize\\\\b|\\\\busize\\\\b|\\\\bbool\\\\b|\\\\bf32\\\\b|\\\\bf64\\\\b|\\\\bi32\\\\b|\\\\bi64\\\\b|\\\\bu32\\\\b|\\\\bu64\\\\b|\\(\\))"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.darcy",
          "match": "(?:darcy\\.btree\\-map/contains|darcy\\.btree\\-map/is\\-empty|darcy\\.hash\\-map/contains|darcy\\.hash\\-map/is\\-empty|darcy\\.btree\\-map/insert|darcy\\.btree\\-map/remove|darcy\\.option/unwrap\\-or|darcy\\.result/unwrap\\-or|darcy\\.hash\\-map/insert|darcy\\.hash\\-map/remove|darcy\\.string/is\\-empty|darcy\\.option/is\\-none|darcy\\.option/is\\-some|darcy\\.btree\\-map/get|darcy\\.btree\\-map/len|darcy\\.btree\\-map/new|darcy\\.option/unwrap|darcy\\.result/is\\-err|darcy\\.result/unwrap|darcy\\.hash\\-map/get|darcy\\.hash\\-map/len|darcy\\.hash\\-map/new|darcy\\.result/is\\-ok|darcy\\.string/split|darcy\\.vec/is\\-empty|darcy\\.fmt/println|darcy\\.option/none|darcy\\.option/some|darcy\\.string/join|darcy\\.string/trim|darcy\\.fmt/format|darcy\\.fmt/pretty|darcy\\.math/clamp|darcy\\.result/err|darcy\\.string/len|darcy\\.fmt/print|darcy\\.result/ok|darcy\\.math/abs|darcy\\.math/max|darcy\\.math/min|darcy\\.vec/get|darcy\\.vec/len|darcy\\.vec/set|darcy\\.io/dbg|bit\\-and|println|bit\\-or|format|pretty|clamp|clone|print|\\->>|abs|add|dbg|div|exp|gte|lte|max|min|mod|mul|sub|\\->|eq|gt|lt)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.darcy",
          "match": "(?:\\->>|\\->|<=|>=|\\&|\\*|\\+|\\-|/|<|=|>|\\|)"
        }
      ]
    }
  }
}
